{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": [
    "domain/**/*.ts",
    "application/**/*.ts",
    "infrastructure/**/*.ts",
    "tests/**/*.ts"
  ]
}